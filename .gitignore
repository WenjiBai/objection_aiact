# ---------- Runtime persistence (CaseFile JSONs are not source-of-truth) ----------
case_storage/

# ---------- RAG: raw corpus + model caches ----------
# Keep curated chunks in rag/corpus.py; ignore bulky raw PDFs + indices.
rag/corpus/*.pdf
rag/corpus/raw/
rag/corpus/downloads/
**/chroma_store/
*.sqlite3
*.duckdb
.cache/
.huggingface/
sentence_transformers_cache/
models/

# ---------- Generated schemas / exports ----------
# schemas/*.json is committed; ignore stale dumps elsewhere.
exports/
out/
output/
reports/
*.pdf.tmp

# ---------- Demo recordings / PPT working files ----------
# Backup demo videos (OBS / Xbox Game Bar) — too big for git.
*.mp4
*.mkv
*.mov
*.avi
recordings/
demo_video/
# PPT lock/backup files; final deck can be committed explicitly.
~$*.pptx
~$*.docx
*.pptx.bak

# ---------- Logs / temp ----------
*.log
logs/
tmp/
temp/
*.tmp

# ---------- A-owned files (avoid conflicts with teammate) ----------
# NOTE: .gitignore only affects UNTRACKED files. If these are already tracked,
# use one of:
#   git update-index --skip-worktree <file>     # keep local edits, don't push
#   git rm --cached <file>                      # stop tracking, then ignore
# A owns the real backend pipeline + symbolic evaluator + agent prompts.
# Uncomment the lines below ONLY if you want B's local edits to never enter git.
#
# backend/api.py
# backend/symbolic/
# backend/agents/
# backend/orchestration/
