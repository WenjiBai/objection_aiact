# Anthropic API key — required for backend LLM calls.
# Copy this file to `.env` (gitignored) and fill in the real key.
ANTHROPIC_API_KEY=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

# Model used by every agent. claude-sonnet-4-5 is what the project was
# specified against; you can override to a newer Sonnet if available.
LLM_MODEL=claude-sonnet-4-6

# Log verbosity for backend modules (DEBUG | INFO | WARNING | ERROR).
LOG_LEVEL=INFO
